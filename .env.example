# ── Database ───────────────────────────────────────────────────────────────────
# For local development (without Docker), point to localhost.
# docker-compose overrides this automatically via its `environment:` block.
DATABASE_URL=postgresql+asyncpg://darkatlas:darkatlas@localhost:5432/darkatlas

# ── Security ───────────────────────────────────────────────────────────────────
# Legacy single key — treated as admin for the "default" org.
# For production, use the /api/v1/auth/keys endpoint to create proper RBAC keys.
API_KEY=dev-api-key-change-in-production

# ── Multi-tenancy (Bonus 1) ────────────────────────────────────────────────────
# Default organization ID used when X-Org-Id header is absent.
# In a real deployment each customer gets their own org slug.
DEFAULT_ORG_ID=default

# ── LLM provider ───────────────────────────────────────────────────────────────
# Choose "groq" (free), "anthropic" (Claude), or "openai" (GPT).
LLM_PROVIDER=groq
GROQ_API_KEY=

# Supply only the key for the provider you chose.
# NEVER commit a file with real keys — this .env.example is the safe template.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model to use for all LangChain chains + the ReAct agent.
# Groq options:     llama-3.3-70b-versatile (free, recommended)
# Anthropic options: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# OpenAI options:    gpt-4o | gpt-4o-mini
LLM_MODEL=llama-3.3-70b-versatile

# ── Rate limiting (Bonus 4) ────────────────────────────────────────────────────
# Format: "<count>/<period>" where period is second | minute | hour
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_LLM=10/minute

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
APP_VERSION=2.0.0
