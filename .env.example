# ── Database ───────────────────────────────────────────────────────────────────
# For local development (without Docker), point to localhost.
# docker-compose overrides this automatically via its `environment:` block.
DATABASE_URL=postgresql+asyncpg://darkatlas:darkatlas@localhost:5432/darkatlas

# ── Security ───────────────────────────────────────────────────────────────────
# Required as X-API-Key header on all write operations.
# Change this before any deployment — treat it like a password.
API_KEY=dev-api-key-change-in-production

# ── LLM provider ───────────────────────────────────────────────────────────────
# Choose "anthropic" (Claude) or "openai" (GPT).
LLM_PROVIDER=anthropic

# Supply only the key for the provider you chose.
# NEVER commit a file with real keys — this .env.example is the safe template.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model to use for all LangChain chains.
# Anthropic options: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# OpenAI options:    gpt-4o | gpt-4o-mini
LLM_MODEL=claude-3-5-sonnet-20241022

# ── App ────────────────────────────────────────────────────────────────────────
# Set DEBUG=true locally to see SQL queries printed to the console.
DEBUG=false
APP_VERSION=1.0.0
